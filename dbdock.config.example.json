{
  "database": {
    "type": "postgres",
    "host": "localhost",
    "port": 5432,
    "username": "postgres",
    "password": "your-password",
    "database": "myapp"
  },
  "storage": {
    "provider": "local",
    "local": {
      "path": "./backups"
    }
  },
  "backup": {
    "compression": {
      "enabled": true,
      "level": 6
    },
    "encryption": {
      "enabled": false
    },
    "schedules": [
      {
        "name": "Daily Backup",
        "cron": "0 2 * * *",
        "enabled": true
      }
    ]
  }
}
