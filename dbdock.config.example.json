{
  "_comment": "DBDock Configuration - Non-Sensitive Settings Only",
  "_security": "Sensitive values (passwords, API keys) should be set via environment variables. See .env.example",

  "database": {
    "type": "postgres",
    "host": "localhost",
    "port": 5432,
    "username": "postgres",
    "database": "myapp"
  },

  "storage": {
    "provider": "local",
    "local": {
      "path": "./backups"
    }
  },

  "backup": {
    "compression": {
      "enabled": true,
      "level": 6
    },
    "encryption": {
      "enabled": false
    },
    "schedules": [
      {
        "name": "Daily Backup",
        "cron": "0 2 * * *",
        "enabled": true
      }
    ]
  }
}