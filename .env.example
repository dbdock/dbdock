# DBDock Environment Variables
# Copy this file to .env.local and fill in your secrets
# NEVER commit .env.local to version control

# =============================================================================
# SECURITY BEST PRACTICE:
# Use this file (.env.local) for sensitive secrets ONLY
# Use dbdock.config.json for non-sensitive configuration
# =============================================================================

# Database Credentials (SENSITIVE - Required)
DBDOCK_DB_PASSWORD=your-database-password

# Storage Provider Credentials (SENSITIVE - Required for S3/R2/Cloudinary)
# For S3 / R2:
DBDOCK_STORAGE_ACCESS_KEY=your-access-key-id
DBDOCK_STORAGE_SECRET_KEY=your-secret-access-key

# For Cloudinary (alternative):
# DBDOCK_CLOUDINARY_API_KEY=your-cloudinary-api-key
# DBDOCK_CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Encryption Secret (SENSITIVE - Required if encryption enabled)
# Generate with: openssl rand -hex 32
DBDOCK_ENCRYPTION_SECRET=

# Email Alert Credentials (SENSITIVE - Optional)
# DBDOCK_SMTP_USER=your-email@example.com
# DBDOCK_SMTP_PASS=your-app-password

# Slack Webhook (SENSITIVE - Optional)
# DBDOCK_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Custom Webhook (SENSITIVE - Optional)
# For WhatsApp, Discord, or any HTTP endpoint that accepts JSON POST requests
# DBDOCK_CUSTOM_WEBHOOK=https://your-server.com/api/webhooks/dbdock

# =============================================================================
# NON-SENSITIVE CONFIGURATION
# These are also supported but should preferably go in dbdock.config.json
# =============================================================================

# Database Connection (non-sensitive)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=your-database

# Storage Provider (non-sensitive)
STORAGE_PROVIDER=local
STORAGE_BUCKET=dbdock-backups
STORAGE_LOCAL_PATH=./backups

# Encryption Settings (non-sensitive)
ENCRYPTION_ENABLED=true
ENCRYPTION_ITERATIONS=100000

# Point-in-Time Recovery (non-sensitive)
PITR_ENABLED=false
PITR_WAL_INTERVAL=300
PITR_RETENTION_DAYS=30

# Config File Path
DBDOCK_CONFIG_PATH=dbdock.config.json

# Security Mode (set to 'true' to enforce env-only secrets)
# DBDOCK_STRICT_MODE=false
